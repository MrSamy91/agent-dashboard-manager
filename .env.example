# Agent Dashboard — Environment Configuration
# Copy this file to .env and edit as needed.

# ─── Agent Mode ───────────────────────────────────────────
# "mock" = simulated agents, no API key needed (great for testing UI)
# "real" = real Claude Code agents (requires claude login)
AGENT_MODE=mock

# ─── Docker only ──────────────────────────────────────────
# Path to your projects on the host (mounted as /workspace in container)
# PROJECTS_DIR=~/projects

# Path to Claude config on the host (auth tokens, sessions)
# CLAUDE_HOME=~/.claude
